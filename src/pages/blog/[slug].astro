---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const date = post.data.date.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Base title={`${post.data.title} - Anna Reshetnyak`} description={post.data.excerpt}>
<article style="padding:60px 0 80px;">

  <a href="/blog" class="back-link">← Все посты</a>

  <div class="post-tags-row">
    {post.data.tags.map(t => <span class="tag">{t}</span>)}
  </div>

  <h1 class="post-h1">{post.data.title}</h1>

  <div class="post-byline">{date} · {post.data.lang === 'both' ? 'RU/EN' : post.data.lang.toUpperCase()}</div>

  <div class="prose">
    <Content />
  </div>

  <div class="post-footer">
    <p>Обсудить или задать вопрос:</p>
    <a href="https://t.me/Areshka1212" target="_blank" class="btn-ghost">Написать в Telegram</a>
  </div>

</article>
</Base>

<style>
.back-link { font-family:'Space Mono',monospace; font-size:12px; color:var(--text-dim); text-decoration:none; letter-spacing:.06em; transition:color .2s; display:inline-block; margin-bottom:32px; }
.back-link:hover { color:var(--purple); }
.post-tags-row { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:16px; }
.post-h1 { font-family:'Space Grotesk',sans-serif; font-size:clamp(28px,5vw,42px); font-weight:700; line-height:1.15; letter-spacing:-.02em; margin-bottom:12px; }
.post-byline { font-family:'Space Mono',monospace; font-size:11px; color:var(--text-dim); letter-spacing:.06em; margin-bottom:48px; }
.post-footer { margin-top:64px; padding-top:40px; border-top:1px solid var(--border); }
.post-footer p { font-size:14px; color:var(--text-muted); margin-bottom:16px; }
</style>
