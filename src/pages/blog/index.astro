---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('blog');
const postPairs = Array.from(
  entries.reduce((map, entry) => {
    const pair = map.get(entry.data.translationKey) ?? { en: null, ru: null };
    pair[entry.data.locale] = entry;
    map.set(entry.data.translationKey, pair);
    return map;
  }, new Map<string, { en: typeof entries[number] | null; ru: typeof entries[number] | null }>())
    .values(),
)
  .filter(pair => pair.en && pair.ru)
  .sort((a, b) => b.en!.data.date.valueOf() - a.en!.data.date.valueOf());
---
<Base title="Blog - Anna Reshetnyak">
<section style="padding:60px 0 80px;">
  <div class="section-label">Writing</div>
  <h1 class="section-title" data-i18n="blogTitle">All posts</h1>
  <div class="posts-list">
    {postPairs.map(({ en, ru }) => (
      <a href={`/blog/${en!.data.translationKey}`} class="post-item">
        <div class="post-content">
          <div
            class="post-title"
            data-post-title
            data-title-ru={ru!.data.title}
            data-title-en={en!.data.title}
          >
            {en!.data.title}
          </div>
          <div
            class="post-excerpt"
            data-post-excerpt
            data-excerpt-ru={ru!.data.excerpt}
            data-excerpt-en={en!.data.excerpt}
          >
            {en!.data.excerpt}
          </div>
          <div class="post-tags">{en!.data.tags.map(t => <span class="tag">{t}</span>)}</div>
        </div>
        <div class="post-meta">
          <span
            class="post-date"
            data-post-date
            data-date-iso={en!.data.date.toISOString()}
          >
            {en!.data.date.toLocaleDateString('en-US',{day:'numeric',month:'short',year:'numeric'})}
          </span>
          <span class="post-lang">RU/EN</span>
        </div>
      </a>
    ))}
  </div>
</section>
</Base>

<script>
const BLOG: Record<string, string> = {
  ru: 'Все посты',
  en: 'All posts',
};

function formatDate(dateIso: string, lang: string) {
  const locale = lang === 'ru' ? 'ru-RU' : 'en-US';
  return new Date(dateIso).toLocaleDateString(locale, { day: 'numeric', month: 'short', year: 'numeric' });
}

function applyBlog(lang: string) {
  document.querySelectorAll<HTMLElement>('[data-i18n="blogTitle"]').forEach(el => {
    el.textContent = BLOG[lang];
  });

  document.querySelectorAll<HTMLElement>('[data-post-title]').forEach(el => {
    el.textContent = lang === 'ru' ? el.dataset.titleRu ?? '' : el.dataset.titleEn ?? '';
  });

  document.querySelectorAll<HTMLElement>('[data-post-excerpt]').forEach(el => {
    el.textContent = lang === 'ru' ? el.dataset.excerptRu ?? '' : el.dataset.excerptEn ?? '';
  });

  document.querySelectorAll<HTMLElement>('[data-post-date]').forEach(el => {
    el.textContent = formatDate(el.dataset.dateIso ?? '', lang);
  });
}

applyBlog(localStorage.getItem('lang') || 'en');
window.addEventListener('langchange', e => applyBlog((e as CustomEvent).detail));
</script>

<style>
.posts-list { display:flex; flex-direction:column; border:1px solid var(--border); border-radius:10px; overflow:hidden; }
.post-item { background:var(--bg-card); padding:20px 24px; text-decoration:none; display:flex; align-items:flex-start; gap:20px; border-bottom:1px solid var(--border); transition:background .2s; }
.post-item:last-child { border-bottom:none; }
.post-item:hover { background:var(--bg-subtle); }
.post-content { flex:1; }
.post-title { font-family:'Space Grotesk',sans-serif; font-size:15px; font-weight:500; color:var(--text); margin-bottom:5px; line-height:1.35; transition:color .2s; }
.post-item:hover .post-title { color:var(--purple); }
.post-excerpt { font-size:13px; color:var(--text-muted); line-height:1.55; }
.post-tags { display:flex; gap:6px; margin-top:10px; flex-wrap:wrap; }
.post-meta { flex-shrink:0; text-align:right; padding-top:2px; }
.post-date { font-family:'Space Mono',monospace; font-size:11px; color:var(--text-dim); display:block; }
.post-lang { font-family:'Space Mono',monospace; font-size:10px; color:var(--purple); display:block; margin-top:4px; }
</style>
